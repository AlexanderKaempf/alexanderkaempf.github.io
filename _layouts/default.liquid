<!DOCTYPE html>
{%- assign lang = page.data.lang | default: "en" -%}
<html lang="{{ lang }}">
  <head>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <title>{{ page.title }} · {{ site.title }}</title>
    <meta name="description" content="{{ page.description | default: site.description }}">
    <link rel="stylesheet" href="/assets/css/style.css">
    <link rel="alternate" type="application/rss+xml" title="{{ site.title }}" href="/rss.xml">
    <!-- MathJax: typeset LaTeX in posts, e.g. \( e^{i\pi}+1=0 \) -->
    <script>
      window.MathJax = {
        tex: { inlineMath: [['\\(', '\\)'], ['$', '$']], displayMath: [['\\[', '\\]'], ['$$', '$$']] },
        options: { skipHtmlTags: ['script', 'noscript', 'style', 'textarea', 'pre', 'code'] }
      };
    </script>
    <script src="https://cdn.jsdelivr.net/npm/mathjax@3/es5/tex-chtml.js" async></script>
  </head>
  <body>
    <header class="site-header">
      <div class="bar">
        <a class="brand" href="{% if lang == 'de' %}/de/{% else %}/{% endif %}">{{ site.title }}</a>
        <nav class="menu">
          {%- if lang == "de" -%}
          <a href="/de/" {% if page.data.nav == "home" %}class="active"{% endif %}>Start</a>
          <a href="/de/about/" {% if page.data.nav == "about" %}class="active"{% endif %}>Über mich</a>
          <a href="/de/posts/" {% if page.data.nav == "posts" %}class="active"{% endif %}>Beiträge</a>
          <a href="/de/contact/" {% if page.data.nav == "contact" %}class="active"{% endif %}>Kontakt</a>
          <a class="lang" href="{{ page.data.alt_url | default: '/' }}" hreflang="en" title="Read in English">EN</a>
          {%- else -%}
          <a href="/" {% if page.data.nav == "home" %}class="active"{% endif %}>Home</a>
          <a href="/about/" {% if page.data.nav == "about" %}class="active"{% endif %}>About</a>
          <a href="/posts/" {% if page.data.nav == "posts" %}class="active"{% endif %}>Posts</a>
          <a href="/contact/" {% if page.data.nav == "contact" %}class="active"{% endif %}>Contact</a>
          <a class="lang" href="{{ page.data.alt_url | default: '/de/' }}" hreflang="de" title="Auf Deutsch lesen">DE</a>
          {%- endif -%}
        </nav>
      </div>
    </header>

    <main class="content">
      {%- if page.collection == "posts" -%}
      <article class="post">
        <header class="post-head">
          <h1>{{ page.title }}</h1>
          <p class="post-meta">
            <time datetime="{{ page.published_date | date: '%Y-%m-%d' }}">
              {%- if lang == "de" -%}
                {{ page.published_date | date: "%d.%m.%Y" }}
              {%- else -%}
                {{ page.published_date | date: "%B %-d, %Y" }}
              {%- endif -%}
            </time>
            {%- if page.tags -%}
            {%- assign tagbase = "/tags/" -%}{%- if lang == "de" -%}{%- assign tagbase = "/de/tags/" -%}{%- endif -%}
            <span class="tag-list">
              {%- for tag in page.tags -%}<a class="tag" href="{{ tagbase }}#{{ tag }}">{{ tag }}</a>{%- endfor -%}
            </span>
            {%- endif -%}
          </p>
        </header>
        {{ page.content }}
      </article>
      {%- else -%}
      {{ page.content }}
      {%- endif -%}
    </main>

    <footer class="site-footer">
      <div class="bar">
        <span>© {{ site.title }}</span>
        <span class="dim">
          {%- if lang == "de" -%}Erstellt mit Cobalt.{%- else -%}Built with Cobalt.{%- endif -%}
        </span>
      </div>
    </footer>
  </body>
</html>
